rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to users collection for authenticated users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow read access to leaderboard data for authenticated users
    match /leaderboard/{document=**} {
      allow read: if request.auth != null;
    }

    // Allow test collection for debugging
    match /test/{document=**} {
      allow read, write: if true;
    }

    // Temporary debugging: Allow all authenticated operations
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}